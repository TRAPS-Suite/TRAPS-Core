Bootstrap: docker
From: ubuntu:20.04

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-dev \
        samtools \
        texlive-latex-base \
        texlive-latex-extra \
        texlive-fonts-recommended \
        texlive-extra-utils \
        ghostscript \
        build-essential \
        && rm -rf /var/lib/apt/lists/*

    python3 -m pip install --upgrade pip
    python3 -m pip install setuptools wheel
    python3 -m pip install deeptools pyGenomeTracks

%environment
    export LC_ALL=C
    export PATH=/usr/local/bin:$PATH

%runscript
    exec "$@"